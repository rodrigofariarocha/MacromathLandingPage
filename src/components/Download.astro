---
---

<section class="download section" id="download">
  <div class="container">
    <div class="download-wrapper fade-in">
      <div class="download-glow"></div>
      <div class="download-grid"></div>

      <div class="download-content">
        <h2 class="download-title">
          Começa a planear
          <span class="text-gradient">refeições mais inteligentes</span>
          hoje.
        </h2>
        <p class="download-subtitle">
          Download gratuito. Sem cartão de crédito. Começa já a controlar a tua nutrição com inteligência.
        </p>

        <div class="download-buttons">
          <a href="#" class="store-button" aria-label="Download na App Store">
            <div class="store-icon">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
            </div>
            <div class="store-text">
              <span class="store-label">Download na</span>
              <span class="store-name">App Store</span>
            </div>
          </a>

          <a href="#" class="store-button" aria-label="Download no Google Play">
            <div class="store-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 0 1 0 1.38l-2.302 2.302L15.396 13l2.302-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302L5.864 2.658z"/>
              </svg>
            </div>
            <div class="store-text">
              <span class="store-label">Disponível no</span>
              <span class="store-name">Google Play</span>
            </div>
          </a>
        </div>

        <p class="download-note">Disponível para iOS 16+ e Android 10+</p>
      </div>
    </div>
  </div>
</section>

<style>
  .download { padding-bottom: var(--space-3xl); }

  .download-wrapper {
    position: relative;
    padding: var(--space-5xl) var(--space-3xl);
    border-radius: var(--radius-2xl);
    overflow: hidden;
    text-align: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }

  .download-glow {
    position: absolute;
    top: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 500px;
    height: 400px;
    background: radial-gradient(circle, rgba(255, 88, 51, 0.06) 0%, transparent 60%);
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .download-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.015) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 50%, black 20%, transparent 70%);
    pointer-events: none;
  }

  .download-content { position: relative; z-index: 1; }

  .download-title {
    font-family: var(--font-display);
    font-size: var(--font-size-4xl);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-lg);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .download-subtitle {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-2xl);
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .download-buttons {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    flex-wrap: wrap;
  }

  .store-button {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 14px 28px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
    color: var(--color-text-primary);
  }

  .store-button:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 88, 51, 0.2);
    transform: translateY(-2px);
  }

  .store-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .store-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .store-label {
    font-size: var(--font-size-xs);
    color: var(--color-text-tertiary);
    font-weight: 500;
    line-height: 1;
  }

  .store-name {
    font-family: var(--font-display);
    font-size: var(--font-size-lg);
    font-weight: 700;
    line-height: 1.2;
  }

  .download-note {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
  }

  @media (max-width: 768px) {
    .download-wrapper { padding: var(--space-3xl) var(--space-xl); }
    .download-buttons {
      flex-direction: column;
      align-items: center;
    }
    .store-button {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>
