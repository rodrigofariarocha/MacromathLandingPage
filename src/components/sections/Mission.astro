---
import StatusBar from '../ui/StatusBar.astro';

const methods = ['pantry.b1', 'pantry.b2', 'pantry.b3', 'pantry.b4', 'pantry.b5'];
---

<section class="section pantry" id="pantry">
  <div class="container pantry-grid">
    <div class="pantry-visual reveal-l">
      <div class="phone-glow"></div>
      <div class="phone">
        <div class="phone-screen">
          <img src="/images/screens/app-pantry.jpg" alt="MacroMath — despensa inteligente" loading="lazy" />
          <StatusBar />
        </div>
      </div>
    </div>

    <div class="pantry-copy">
      <span class="eyebrow reveal" data-i18n="pantry.eyebrow">Despensa</span>
      <h2 class="title reveal d1" data-i18n="pantry.title">Sabe sempre o que tens em casa</h2>
      <p class="lead reveal d2" data-i18n="pantry.sub">
        Adiciona alimentos de cinco formas diferentes e nunca mais compres o que já tens.
      </p>

      <ul class="methods">
        {methods.map((k, i) => (
          <li class={`method reveal d${(i % 5) + 1}`}>
            <span class="method-arrow">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            </span>
            <span class="method-label" data-i18n={k}></span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .pantry-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
  }
  .pantry-copy .title { margin-bottom: var(--sp-md); }
  .methods { display: flex; flex-direction: column; margin-top: var(--sp-lg); }
  .method {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.95rem 0.25rem;
    border-bottom: 1px solid var(--border);
    font-weight: 600;
    font-size: var(--fs-lg);
    color: var(--text);
    transition: padding var(--t-base), color var(--t-base);
  }
  .method:last-child { border-bottom: none; }
  .method:hover { padding-left: 0.7rem; color: var(--brand-strong); }
  .method-arrow {
    flex-shrink: 0;
    display: grid; place-items: center;
    color: var(--brand-strong);
    transition: transform var(--t-base);
  }
  .method:hover .method-arrow { transform: translateX(4px); }
  .method-label { letter-spacing: -0.01em; }

  .pantry-visual { position: relative; display: flex; justify-content: center; }
  .pantry-visual .phone { animation: float 7s ease-in-out infinite 0.5s; }
  .pantry-visual .phone-glow {
    position: absolute; top: 50%; left: 50%; width: 340px; height: 340px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, var(--glow), transparent 68%); filter: blur(30px);
  }

  @media (max-width: 900px) {
    .pantry-grid { grid-template-columns: 1fr; }
    .pantry-visual { order: -1; }
  }
</style>
