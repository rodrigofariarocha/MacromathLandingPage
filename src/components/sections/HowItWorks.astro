---
import StatusBar from '../ui/StatusBar.astro';

const steps = [
  { n: '01', t: 'how.1.t', d: 'how.1.d' },
  { n: '02', t: 'how.2.t', d: 'how.2.d' },
  { n: '03', t: 'how.3.t', d: 'how.3.d' },
];
---

<section class="section how" id="how">
  <div class="container how-grid">
    <div class="how-visual reveal-l">
      <div class="phone-glow"></div>
      <div class="phone">
        <div class="phone-screen">
          <img src="/images/screens/app-onboarding.jpg" alt="MacroMath — recomendação diária" loading="lazy" />
          <StatusBar />
        </div>
      </div>
    </div>

    <div class="how-copy">
      <span class="eyebrow reveal" data-i18n="how.eyebrow">Como funciona</span>
      <h2 class="title reveal d1" data-i18n="how.title">Do objetivo ao prato em 3 passos</h2>

      <div class="steps" id="how-steps">
        <!-- scroll-driven progress track -->
        <div class="steps-line" id="how-line" aria-hidden="true">
          <div class="steps-line-fill" id="how-line-fill"></div>
        </div>

        {steps.map((s, i) => (
          <div class={`step reveal d${i + 1}`}>
            <span class="step-n">{s.n}</span>
            <div>
              <h3 class="step-t" data-i18n={s.t}></h3>
              <p class="step-d" data-i18n={s.d}></p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .how-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
  }
  .how-visual { position: relative; display: flex; justify-content: center; }
  .how-visual .phone { animation: float 7s ease-in-out infinite; }
  .how-visual .phone-glow {
    position: absolute; top: 50%; left: 50%; width: 340px; height: 340px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, var(--glow), transparent 68%); filter: blur(30px);
  }

  .how-copy .title { margin-bottom: var(--sp-xl); }
  .steps { position: relative; display: flex; flex-direction: column; gap: 1.6rem; }

  /* single track: grey background, orange fill inside */
  .steps-line {
    position: absolute;
    left: 23px;
    width: 1.5px;
    background: var(--border-strong);
    border-radius: 1px;
    /* top + height set by JS */
  }
  .steps-line-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: var(--brand);
    border-radius: 1px;
    will-change: height;
  }

  .step {
    position: relative;
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
  }
  .step-n {
    position: relative;
    flex-shrink: 0;
    font-size: 1.1rem;
    font-weight: 800;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 14px;
    color: var(--text);
    background: var(--surface-2);
    border: 1px solid var(--border);
    transition: color 0.35s ease, background 0.35s ease, border-color 0.35s ease;
    z-index: 1;
  }
  .step-n.is-active {
    color: #fff;
    background: var(--brand);
    border-color: var(--brand);
  }
  .step-t { font-size: var(--fs-lg); font-weight: 700; margin-bottom: 0.3rem; letter-spacing: -0.01em; }
  .step-d { font-size: var(--fs-sm); color: var(--text-2); line-height: 1.65; }

  @media (max-width: 900px) {
    .how-grid { grid-template-columns: 1fr; }
    .how-visual { order: -1; }
  }
</style>

<script>
  (() => {
    const stepsEl = document.getElementById('how-steps')!;
    const line    = document.getElementById('how-line')!;
    const fill    = document.getElementById('how-line-fill')!;
    if (!stepsEl || !line || !fill) return;

    const badges = Array.from(stepsEl.querySelectorAll('.step-n'));
    if (badges.length < 2) return;

    // Position the track from the centre of badge 1 to the centre of the last badge.
    function positionLine() {
      const base      = stepsEl.getBoundingClientRect();
      const firstRect = badges[0].getBoundingClientRect();
      const lastRect  = badges[badges.length - 1].getBoundingClientRect();

      const top    = firstRect.top - base.top + firstRect.height / 2;
      const height = lastRect.top  - firstRect.top;

      line.style.top    = top    + 'px';
      line.style.height = height + 'px';
    }

    // Drive fill height (0–100 %) based on scroll: starts when badge 1 hits
    // 75 % of the viewport, finishes when the last badge hits 35 %.
    function updateProgress() {
      const firstRect = badges[0].getBoundingClientRect();
      const lastRect  = badges[badges.length - 1].getBoundingClientRect();
      const vh        = window.innerHeight;

      const startY = firstRect.top + firstRect.height / 2 - vh * 0.75;
      const endY   = lastRect.top  + lastRect.height  / 2 - vh * 0.35;
      const range  = endY - startY;

      const p = range !== 0 ? Math.max(0, Math.min(1, -startY / range)) : 0;

      fill.style.height = (p * 100) + '%';

      // Activate each badge when the fill line reaches its centre.
      badges.forEach((badge, i) => {
        const threshold = i / (badges.length - 1); // 0, 0.5, 1
        badge.classList.toggle('is-active', p >= threshold);
      });
    }

    positionLine();
    updateProgress();

    window.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', () => { positionLine(); updateProgress(); }, { passive: true });
  })();
</script>
