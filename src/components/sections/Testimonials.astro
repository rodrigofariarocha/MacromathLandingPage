---
const plans = [
  {
    key: 'free',
    featured: false,
    nameKey: 'price.free.name',
    amount: '0€',
    perKey: 'price.free.per',
    items: ['price.free.1', 'price.free.2', 'price.free.3', 'price.free.4'],
    ctaKey: 'price.free.cta',
    ctaClass: 'btn-ghost',
  },
  {
    key: 'pro',
    featured: true,
    nameKey: 'price.pro.name',
    badgeKey: 'price.pro.badge',
    amount: '4,99€',
    perKey: 'price.pro.per',
    items: ['price.pro.1', 'price.pro.2', 'price.pro.3', 'price.pro.4', 'price.pro.5'],
    ctaKey: 'price.pro.cta',
    ctaClass: 'btn-primary',
  },
  {
    key: 'year',
    featured: false,
    nameKey: 'price.year.name',
    badgeKey: 'price.year.badge',
    saveKey: 'price.year.save',
    amount: '39,99€',
    perKey: 'price.year.per',
    items: ['price.year.1', 'price.year.2', 'price.year.3', 'price.year.4', 'price.year.5'],
    ctaKey: 'price.year.cta',
    ctaClass: 'btn-ghost',
  },
];
---

<section class="section pricing" id="pricing">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow reveal" data-i18n="price.eyebrow">Preços</span>
      <h2 class="title reveal d1" data-i18n="price.title">Começa grátis. Faz upgrade quando quiseres.</h2>
    </div>

    <div class="plans">
      {plans.map((p, i) => (
        <article class={`plan reveal-s d${i + 1}${p.featured ? ' plan-pro' : ''}`}>
          {p.badgeKey && (
            <span class={`plan-badge${p.featured ? '' : ' plan-badge-soft'}`} data-i18n={p.badgeKey}></span>
          )}
          <div class="plan-top">
            <span class="plan-name" data-i18n={p.nameKey}></span>
            <div class="plan-price">
              <span class="plan-amount">{p.amount}</span>
              <span class="plan-per" data-i18n={p.perKey}></span>
            </div>
            {p.saveKey && <span class="plan-save" data-i18n={p.saveKey}></span>}
          </div>
          <div class="plan-divider"></div>
          <ul class="plan-list">
            {p.items.map((it) => (
              <li>
                <span class={`tick${p.featured ? ' tick-pro' : ''}`}>
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                </span>
                <span data-i18n={it}></span>
              </li>
            ))}
          </ul>
          <a href="#download" class={`btn ${p.ctaClass} plan-cta`} data-i18n={p.ctaKey}></a>
        </article>
      ))}
    </div>

    <p class="plan-note reveal" data-i18n="price.note">Cancela quando quiseres. Sem compromissos.</p>
  </div>
</section>

<style>
  .plans {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: stretch;
    gap: 1.4rem;
    max-width: 1080px;
    margin: 0 auto;
  }
  .plan {
    display: flex;
    flex-direction: column;
    padding: 2.2rem 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow-sm);
    position: relative;
    transition: transform var(--t-base), box-shadow var(--t-base), border-color var(--t-base);
  }
  .plan:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); border-color: var(--border-strong); }

  .plan-pro {
    border: 1.5px solid transparent;
    background:
      linear-gradient(var(--surface), var(--surface)) padding-box,
      var(--brand-gradient) border-box;
    box-shadow: var(--shadow-md), 0 0 0 5px color-mix(in srgb, var(--brand) 7%, transparent);
    z-index: 1;
  }
  .plan-pro:hover { box-shadow: var(--shadow-lg), 0 0 0 5px color-mix(in srgb, var(--brand) 10%, transparent); }

  .plan-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    font-size: var(--fs-xs);
    font-weight: 700;
    padding: 0.4rem 1rem;
    border-radius: var(--r-full);
    background: var(--brand-gradient);
    color: #fff;
    box-shadow: var(--shadow-brand);
    white-space: nowrap;
  }
  .plan-badge-soft {
    background: var(--surface-2);
    color: var(--text-2);
    border: 1px solid var(--border-strong);
    box-shadow: var(--shadow-sm);
  }

  .plan-top { display: flex; flex-direction: column; align-items: flex-start; gap: 0.85rem; }
  .plan-name {
    font-size: var(--fs-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-2);
    padding: 0.35rem 0.85rem;
    border-radius: var(--r-full);
    background: var(--surface-2);
  }
  .plan-pro .plan-name { color: var(--brand-strong); background: var(--brand-gradient-soft); }
  .plan-price { display: flex; align-items: baseline; gap: 0.45rem; }
  .plan-amount { font-size: 2.9rem; font-weight: 800; letter-spacing: -0.04em; line-height: 1; }
  .plan-per { font-size: var(--fs-sm); color: var(--text-3); font-weight: 600; }
  .plan-save {
    font-size: var(--fs-xs);
    font-weight: 700;
    color: var(--brand-strong);
    background: var(--brand-gradient-soft);
    padding: 0.3rem 0.7rem;
    border-radius: var(--r-full);
  }

  .plan-divider { height: 1px; background: var(--border); margin: 1.5rem 0; }

  .plan-list { display: flex; flex-direction: column; gap: 0.9rem; flex: 1; margin-bottom: 1.8rem; }
  .plan-list li { display: flex; align-items: center; gap: 0.7rem; font-size: var(--fs-sm); font-weight: 500; color: var(--text); }
  .tick {
    flex-shrink: 0;
    width: 22px; height: 22px;
    display: grid; place-items: center;
    border-radius: 50%;
    background: var(--surface-2);
    color: var(--text-2);
  }
  .tick-pro { background: var(--brand-gradient); color: #fff; }

  .plan-cta { width: 100%; margin-top: auto; }
  .plan-note { text-align: center; margin-top: var(--sp-2xl); color: var(--text-3); font-size: var(--fs-sm); }

  @media (max-width: 980px) {
    .plans { grid-template-columns: minmax(0, 440px); justify-content: center; gap: 2rem; }
  }
</style>
