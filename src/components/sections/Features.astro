---
import StatusBar from '../ui/StatusBar.astro';

const features = [
  { t: 'feat.1.t', d: 'feat.1.d', img: '/images/screens/app-home.jpg', icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
    tx: 'Macros em tempo real', dx: 'Calorias, proteína, hidratos e gordura visualizados em anéis claros, atualizados a cada refeição.' },
  { t: 'feat.2.t', d: 'feat.2.d', img: '/images/screens/app-ai.jpg', icon: '<path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6z"/><path d="M18 14l.8 2.2L21 17l-2.2.8L18 20l-.8-2.2L15 17l2.2-.8z"/>',
    tx: 'MacroAI — assistente nutricional', dx: 'Pergunta qualquer coisa sobre nutrição, gera receitas com o que tens e cria listas de compras inteligentes.' },
  { t: 'feat.3.t', d: 'feat.3.d', img: '/images/screens/app-pantry.jpg', icon: '<rect x="3" y="3" width="18" height="5" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 12h4"/>',
    tx: 'Despensa inteligente', dx: 'Controla o teu stock, lê códigos de barras, digitaliza talões ou identifica alimentos por foto.' },
  { t: 'feat.4.t', d: 'feat.4.d', img: '/images/screens/app-progress.jpg', icon: '<path d="M3 17l5-5 4 3 6-7"/><path d="M3 21h18"/>',
    tx: 'Evolução e progresso', dx: 'Acompanha o teu peso e macros ao longo do tempo com gráficos elegantes e fáceis de ler.' },
  { t: 'feat.5.t', d: 'feat.5.d', img: '/images/screens/app-shopping.jpg', icon: '<circle cx="9" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/><path d="M2 3h2l2.5 12.5a2 2 0 0 0 2 1.5h7.5a2 2 0 0 0 2-1.5L21 7H6"/>',
    tx: 'Lista de compras com IA', dx: 'A IA sugere o que comprar com base no teu perfil, objetivos e no que já tens em casa.' },
  { t: 'feat.6.t', d: 'feat.6.d', img: '/images/screens/app-login.jpg', icon: '<path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><path d="M10 17l5-5-5-5"/><path d="M15 12H3"/>',
    tx: 'Login e sincronização', dx: 'Entra com a tua conta e tem os teus dados sincronizados em qualquer dispositivo, em segurança.' },
];
---

<section class="section features" id="features">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow reveal" data-i18n="feat.eyebrow">Funcionalidades</span>
      <h2 class="title reveal d1" data-i18n="feat.title">Uma app, tudo o que a tua dieta precisa</h2>
      <p class="lead reveal d2" data-i18n="feat.sub">Desenhada para ser simples no dia-a-dia e poderosa quando precisas.</p>
    </div>

    <div class="feature-switch">
      <ul class="feature-list reveal d1">
        {features.map((f, i) => (
          <li>
            <button
              class={`feature-row${i === 0 ? ' is-active' : ''}`}
              data-img={f.img}
              aria-pressed={i === 0 ? 'true' : 'false'}
            >
              <span class="feature-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
              </span>
              <span class="feature-text">
                <span class="feature-title" data-i18n={f.t}>{f.tx}</span>
                <span class="feature-desc" data-i18n={f.d}>{f.dx}</span>
              </span>
            </button>
          </li>
        ))}
      </ul>

      <div class="feature-stage reveal-r d2">
        <div class="phone-glow"></div>
        <div class="phone feature-phone">
          <div class="phone-screen">
            <img id="feature-screen" src={features[0].img} alt="MacroMath" loading="lazy" />
            <StatusBar />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const rows = Array.from(document.querySelectorAll('.feature-row'));
    const img = document.getElementById('feature-screen');
    if (!rows.length || !img) return;

    function select(row) {
      const next = row.getAttribute('data-img');
      if (img.getAttribute('src') === next) return;
      rows.forEach((r) => {
        const active = r === row;
        r.classList.toggle('is-active', active);
        r.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      img.style.opacity = '0';
      setTimeout(() => {
        img.src = next;
        img.style.opacity = '1';
      }, 180);
    }

    rows.forEach((r) => {
      r.addEventListener('click', () => select(r));
      r.addEventListener('mouseenter', () => select(r));
    });
  })();
</script>

<style>
  .feature-switch {
    display: grid;
    grid-template-columns: 1fr 0.78fr;
    align-items: center;
    gap: clamp(2rem, 6vw, 4.5rem);
  }

  /* Selectable feature list */
  .feature-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .feature-row {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.1rem 1.2rem;
    text-align: left;
    border-radius: var(--r-lg);
    border: 1px solid transparent;
    background: transparent;
    cursor: pointer;
    transition: background var(--t-base), border-color var(--t-base), transform var(--t-base);
  }
  .feature-row:hover { background: var(--surface-2); }
  .feature-row.is-active {
    background: var(--surface);
    border-color: var(--border);
    box-shadow: var(--shadow-sm);
  }

  .feature-icon {
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    color: var(--text-2);
    background: var(--surface-2);
    border: 1px solid var(--border);
    transition: transform var(--t-base), background var(--t-base), color var(--t-base), border-color var(--t-base);
  }
  .feature-row.is-active .feature-icon {
    color: var(--brand-strong);
  }

  .feature-text { display: flex; flex-direction: column; gap: 0.25rem; }
  .feature-title { font-size: var(--fs-lg); font-weight: 700; letter-spacing: -0.01em; }
  .feature-desc {
    font-size: var(--fs-sm);
    color: var(--text-2);
    line-height: 1.6;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height var(--t-base), opacity var(--t-base), margin var(--t-base);
  }
  .feature-row.is-active .feature-desc { max-height: 120px; opacity: 1; margin-top: 0.15rem; }

  /* Single phone stage */
  .feature-stage { position: relative; display: flex; justify-content: center; }
  .feature-phone { animation: float 6.5s ease-in-out infinite; }
  .feature-stage .phone-glow {
    position: absolute; top: 50%; left: 50%; width: 360px; height: 360px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, var(--glow), transparent 68%);
    filter: blur(34px);
  }
  #feature-screen { transition: opacity 0.18s var(--ease); }

  @media (max-width: 900px) {
    .feature-switch { grid-template-columns: 1fr; gap: 2.5rem; }
    .feature-stage { order: -1; }
    .feature-stage .phone { max-width: 230px; }
  }
  @media (max-width: 520px) {
    .feature-row { padding: 0.95rem 1rem; gap: 0.85rem; }
    .feature-icon { width: 42px; height: 42px; }
  }
</style>
