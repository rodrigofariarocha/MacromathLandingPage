---
import StatusBar from '../ui/StatusBar.astro';

const features = [
  { t: 'feat.1.t', d: 'feat.1.d', img: '/images/screens/app-home.jpg', icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
    tx: 'Macros em tempo real', dx: 'Calorias, proteína, hidratos e gordura visualizados em anéis claros, atualizados a cada refeição.' },
  { t: 'feat.2.t', d: 'feat.2.d', img: '/images/screens/app-ai.jpg', icon: '<path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6z"/><path d="M18 14l.8 2.2L21 17l-2.2.8L18 20l-.8-2.2L15 17l2.2-.8z"/>',
    tx: 'MacroAI — assistente nutricional', dx: 'Pergunta qualquer coisa sobre nutrição, gera receitas com o que tens e cria listas de compras inteligentes.' },
  { t: 'feat.3.t', d: 'feat.3.d', img: '/images/screens/app-pantry.jpg', icon: '<rect x="5" y="3" width="14" height="18" rx="2"/><path d="M9 7h0M9 12h0"/>',
    tx: 'Despensa inteligente', dx: 'Controla o teu stock, lê códigos de barras, digitaliza talões ou identifica alimentos por foto.' },
  { t: 'feat.4.t', d: 'feat.4.d', img: '/images/screens/app-progress.jpg', icon: '<path d="M3 17l5-5 4 3 6-7"/><path d="M3 21h18"/>',
    tx: 'Evolução e progresso', dx: 'Acompanha o teu peso e macros ao longo do tempo com gráficos elegantes e fáceis de ler.' },
  { t: 'feat.5.t', d: 'feat.5.d', img: '/images/screens/app-shopping.jpg', icon: '<circle cx="9" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/><path d="M2 3h2l2.5 12.5a2 2 0 0 0 2 1.5h7.5a2 2 0 0 0 2-1.5L21 7H6"/>',
    tx: 'Lista de compras com IA', dx: 'A IA sugere o que comprar com base no teu perfil, objetivos e no que já tens em casa.' },
  { t: 'feat.6.t', d: 'feat.6.d', img: '/images/screens/app-meal.jpg', icon: '<path d="M12 3c3 3.5 5 6 5 9a5 5 0 0 1-10 0c0-3 2-5.5 5-9z"/>',
    tx: 'Hidratação e refeições', dx: 'Regista a água do dia e organiza as refeições, do pequeno-almoço ao jantar, sem complicações.' },
];
---

<section class="section features" id="features">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow reveal" data-i18n="feat.eyebrow">Funcionalidades</span>
      <h2 class="title reveal d1" data-i18n="feat.title">Uma app, tudo o que a tua dieta precisa</h2>
      <p class="lead reveal d2" data-i18n="feat.sub">Desenhada para ser simples no dia-a-dia e poderosa quando precisas.</p>
    </div>

    <div class="feature-grid">
      {features.map((f, i) => (
        <button class={`feature-card card reveal d${(i % 3) + 1}`} data-img={f.img} aria-label="Ver">
          <span class="feature-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon} />
          </span>
          <h3 class="feature-title" data-i18n={f.t}>{f.tx}</h3>
          <p class="feature-desc" data-i18n={f.d}>{f.dx}</p>
          <span class="feature-more">
            <span data-i18n="feat.more">Ver funcionalidade</span>
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </span>
        </button>
      ))}
    </div>
  </div>

  <!-- Feature modal -->
  <div class="feat-modal" id="feat-modal" aria-hidden="true">
    <div class="feat-modal-backdrop" data-close></div>
    <div class="feat-modal-card" role="dialog" aria-modal="true">
      <button class="feat-modal-close" data-close aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
      </button>
      <div class="feat-modal-phone">
        <div class="phone">
          <div class="phone-screen"><img id="feat-modal-img" src="" alt="" /><StatusBar /></div>
        </div>
      </div>
      <div class="feat-modal-body">
        <span class="feat-modal-tag" data-i18n="feat.eyebrow">Funcionalidades</span>
        <h3 class="feat-modal-title" id="feat-modal-title"></h3>
        <p class="feat-modal-desc" id="feat-modal-desc"></p>
        <a href="#download" class="btn btn-primary" data-close-cta data-i18n="hero.cta1">Descarregar grátis</a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const modal = document.getElementById('feat-modal');
    if (!modal) return;
    const img = document.getElementById('feat-modal-img');
    const title = document.getElementById('feat-modal-title');
    const desc = document.getElementById('feat-modal-desc');

    function open(card) {
      img.src = card.getAttribute('data-img');
      title.textContent = card.querySelector('.feature-title').textContent;
      desc.textContent = card.querySelector('.feature-desc').textContent;
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('no-scroll');
    }
    function close() {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('no-scroll');
    }

    document.querySelectorAll('.feature-card').forEach((c) => c.addEventListener('click', () => open(c)));
    modal.querySelectorAll('[data-close]').forEach((b) => b.addEventListener('click', close));
    modal.querySelector('[data-close-cta]')?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  })();
</script>

<style>
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }
  .feature-card {
    padding: 2rem 1.9rem;
    text-align: left;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-md);
    border-color: var(--border-strong);
  }
  .feature-icon {
    position: relative;
    display: grid;
    place-items: center;
    width: 54px;
    height: 54px;
    border-radius: 16px;
    margin-bottom: 1.3rem;
    color: var(--text);
    background: var(--surface-2);
    border: 1px solid var(--border);
    transition: transform var(--t-base), background var(--t-base), color var(--t-base), border-color var(--t-base);
  }
  .feature-card:hover .feature-icon {
    color: var(--bg);
    background: var(--text);
    border-color: var(--text);
  }
  .feature-title { font-size: var(--fs-lg); font-weight: 700; letter-spacing: -0.01em; margin-bottom: 0.5rem; }
  .feature-desc { font-size: var(--fs-sm); color: var(--text-2); line-height: 1.65; margin-bottom: 1.1rem; }
  .feature-title,
  .feature-desc { position: relative; }
  .feature-more {
    position: relative;
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--brand-strong);
  }
  .feature-more svg { transition: transform var(--t-fast); }
  .feature-card:hover .feature-more svg { transform: translateX(4px); }

  /* Modal */
  .feat-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: grid;
    place-items: center;
    padding: 1.5rem;
    visibility: hidden;
    opacity: 0;
    transition: opacity var(--t-base), visibility var(--t-base);
  }
  .feat-modal.open { visibility: visible; opacity: 1; }
  .feat-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 9, 13, 0.62);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .feat-modal-card {
    position: relative;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    max-width: 760px;
    width: 100%;
    padding: clamp(1.5rem, 4vw, 2.6rem);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow-lg);
    transform: scale(0.9) translateY(20px);
    opacity: 0;
    transition: transform 0.45s var(--ease), opacity 0.45s var(--ease);
  }
  .feat-modal.open .feat-modal-card { transform: none; opacity: 1; }
  .feat-modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--surface-2);
    color: var(--text-2);
    transition: background var(--t-fast), color var(--t-fast);
    z-index: 2;
  }
  .feat-modal-close:hover { background: var(--brand-gradient); color: #fff; }
  .feat-modal-phone { display: flex; justify-content: center; }
  .feat-modal-phone .phone { width: 100%; max-width: 220px; }
  .feat-modal-tag {
    display: inline-block;
    font-size: var(--fs-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--brand-strong);
    margin-bottom: 0.6rem;
  }
  .feat-modal-title { font-size: var(--fs-2xl); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 0.7rem; line-height: 1.15; }
  .feat-modal-desc { font-size: var(--fs-base); color: var(--text-2); line-height: 1.7; margin-bottom: 1.6rem; }

  @media (max-width: 900px) { .feature-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) {
    .feature-grid { grid-template-columns: 1fr; }
    .feat-modal-card { grid-template-columns: 1fr; text-align: center; max-width: 360px; max-height: 88vh; overflow-y: auto; }
    .feat-modal-phone { display: flex; justify-content: center; }
    .feat-modal-phone .phone { max-width: 170px; }
    .feat-modal-more, .feature-more { justify-content: center; }
  }
</style>
